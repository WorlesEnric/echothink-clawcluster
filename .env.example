# -----------------------------------------------------------------------------
# EchoThink ClawCluster environment contract
# Copy this file to .env and replace every placeholder before production use.
# Never commit real tokens, secrets, or private endpoints.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Global cluster identity
# -----------------------------------------------------------------------------
DOMAIN=clawcluster.example.com
CLUSTER_NAME=clawcluster-prod

# -----------------------------------------------------------------------------
# Higress gateway
# Exposed publicly by the local/single-node compose baseline.
# -----------------------------------------------------------------------------
HIGRESS_ADMIN_PORT=9000
HIGRESS_HTTP_PORT=8080
HIGRESS_HTTPS_PORT=8443

# -----------------------------------------------------------------------------
# Tuwunel Matrix homeserver
# TUWUNEL_DB_URL should point at the existing EchoThink Postgres/Supabase estate
# or a dedicated Matrix database reachable from this cluster.
# -----------------------------------------------------------------------------
TUWUNEL_SERVER_NAME=matrix.clawcluster.example.com
TUWUNEL_REGISTRATION_TOKEN=replace-with-long-random-registration-token
TUWUNEL_DB_URL=postgresql://matrix_user:replace-me@postgres.echothink.internal:5432/tuwunel
MATRIX_HOMESERVER_URL=http://tuwunel.clawcluster.svc:6167
MATRIX_ACCESS_TOKEN=replace-with-matrix-service-account-token

# -----------------------------------------------------------------------------
# Element Web
# Base URL for the default Matrix homeserver Element should target.
# -----------------------------------------------------------------------------
ELEMENT_WEB_DEFAULT_SERVER=https://matrix.clawcluster.example.com

# -----------------------------------------------------------------------------
# HiClaw manager / OpenClaw control plane
# -----------------------------------------------------------------------------
HICLAW_MANAGER_PORT=8088
HICLAW_MANAGER_LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Worker runtime defaults
# WORKER_REPLICAS is an intent/default value. Plain Docker Compose typically uses
# `docker compose up --scale <service>=<n>` for live scaling.
# -----------------------------------------------------------------------------
WORKER_IMAGE=ghcr.io/opencoai/openclaw:latest
WORKER_REPLICAS=1

# -----------------------------------------------------------------------------
# Shared storage (existing EchoThink MinIO)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=https://minio.echothink.internal
MINIO_ACCESS_KEY=replace-with-minio-access-key
MINIO_SECRET_KEY=replace-with-minio-secret-key
MINIO_HICLAW_BUCKET=clawcluster-sharedfs

# -----------------------------------------------------------------------------
# EchoThink upstream service URLs and credentials
# -----------------------------------------------------------------------------
OUTLINE_URL=https://outline.echothink.internal
OUTLINE_API_TOKEN=replace-with-outline-api-token

GITLAB_URL=https://gitlab.echothink.internal
GITLAB_TOKEN=replace-with-gitlab-access-token

SUPABASE_URL=https://supabase.echothink.internal
SUPABASE_ANON_KEY=replace-with-supabase-anon-key
SUPABASE_SERVICE_KEY=replace-with-supabase-service-role-key

HATCHET_SERVER_URL=https://hatchet.echothink.internal

GRAPHITI_URL=https://graphiti.echothink.internal

LITELLM_URL=https://litellm.echothink.internal
LITELLM_API_KEY=replace-with-litellm-api-key

LANGFUSE_URL=https://langfuse.echothink.internal
LANGFUSE_SECRET_KEY=replace-with-langfuse-secret-key

DIFY_URL=https://dify.echothink.internal
DIFY_API_KEY=replace-with-dify-api-key

N8N_URL=https://n8n.echothink.internal
N8N_API_KEY=replace-with-n8n-api-key

# -----------------------------------------------------------------------------
# Bridge services
# These values control both container listeners and host port exposure.
# -----------------------------------------------------------------------------
INTAKE_BRIDGE_PORT=8100
PUBLISHER_BRIDGE_PORT=8101
POLICY_BRIDGE_PORT=8102
OBSERVABILITY_BRIDGE_PORT=8103

# -----------------------------------------------------------------------------
# Security and cross-cluster trust
# -----------------------------------------------------------------------------
VPN_PEER_ENDPOINT=vpn-peer.clawcluster.example.com:51820
MTLS_CA_CERT_PATH=/run/secrets/clawcluster-ca.pem
WORKER_JWT_SECRET=replace-with-long-random-worker-jwt-secret
