{
  "gateway": {
    "mode": "local",
    "port": 18799,
    "auth": {
      "token": "${HICLAW_MANAGER_GATEWAY_KEY}"
    },
    "remote": {
      "token": "${HICLAW_MANAGER_GATEWAY_KEY}"
    }
  },
  "channels": {
    "matrix": {
      "enabled": true,
      "homeserver": "http://127.0.0.1:6167",
      "accessToken": "${MATRIX_ACCESS_TOKEN_MANAGER}",
      "dm": {
        "policy": "allowlist",
        "allowFrom": [
          "@${HICLAW_ADMIN_USER}:${HICLAW_MATRIX_DOMAIN}"
        ]
      },
      "groupPolicy": "allowlist",
      "groupAllowFrom": [
        "@${HICLAW_ADMIN_USER}:${HICLAW_MATRIX_DOMAIN}"
      ],
      "groups": {
        "*": {
          "allow": true,
          "requireMention": true
        }
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "hiclaw-gateway": {
        "baseUrl": "${LITELLM_URL}/v1",
        "apiKey": "${LITELLM_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "cost-effective",
            "name": "cost-effective",
            "reasoning": true,
            "contextWindow": 960000,
            "maxTokens": 64000,
            "input": [
              "text",
              "image"
            ]
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "timeoutSeconds": 1800,
      "workspace": "/root",
      "model": {
        "primary": "hiclaw-gateway/cost-effective"
      },
      "maxConcurrent": 10,
      "subagents": {
        "maxConcurrent": 16
      }
    }
  },
  "session": {
    "dmScope": "per-channel-peer",
    "resetByType": {
      "dm": {
        "mode": "daily",
        "atHour": 4
      },
      "group": {
        "mode": "idle",
        "idleMinutes": 2880
      }
    }
  },
  "hooks": {
    "enabled": true,
    "token": "${HICLAW_MANAGER_GATEWAY_KEY}"
  },
  "plugins": {
    "load": {
      "paths": [
        "/opt/openclaw/extensions/matrix"
      ]
    },
    "entries": {
      "matrix": {
        "enabled": true
      }
    }
  }
}
