{
  "name": "manager",
  "version": "1.0.0",
  "role": "manager",
  "description": "Coordinates the ClawCluster workforce, routing plans, execution, and escalations.",
  "model": "claude-opus-4-6",
  "systemPromptExtensions": [
    "Clarify objectives, constraints, risks, and approvals before dispatching work.",
    "Delegate to the smallest capable set of workers and keep ownership explicit.",
    "Maintain a single coherent execution narrative across all active tasks.",
    "Escalate to humans for approval-sensitive, risky, or materially ambiguous actions.",
    "Avoid micromanagement; define interfaces, checkpoints, and definitions of done."
  ],
  "mcpServers": {
    "outline-mcp": {
      "type": "sse",
      "url": "http://outline.echothink.svc/mcp",
      "args": [],
      "env": {
        "OUTLINE_API_URL": "http://outline.echothink.svc/api",
        "OUTLINE_API_TOKEN": "${OUTLINE_API_TOKEN}"
      }
    },
    "gitlab-mcp": {
      "type": "sse",
      "url": "http://higress.clawcluster.svc/mcp/gitlab",
      "args": [],
      "env": {
        "GITLAB_BASE_URL": "http://gitlab.echothink.svc",
        "GITLAB_API_TOKEN": "${GITLAB_API_TOKEN}",
        "HIGRESS_CONSUMER_TOKEN": "${HIGRESS_CONSUMER_TOKEN_MANAGER}"
      }
    },
    "supabase-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase"
      ],
      "env": {
        "SUPABASE_URL": "http://supabase-kong.echothink.svc:8000",
        "SUPABASE_SERVICE_ROLE_KEY": "${SUPABASE_SERVICE_ROLE_KEY}",
        "POSTGRES_URL": "${POSTGRES_URL}"
      }
    },
    "graphiti-mcp": {
      "type": "sse",
      "url": "http://graphiti.echothink.svc:8000/mcp",
      "args": [],
      "env": {
        "GRAPHITI_BASE_URL": "http://graphiti.echothink.svc:8000",
        "GRAPHITI_API_TOKEN": "${GRAPHITI_API_TOKEN}"
      }
    },
    "minio-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-s3"
      ],
      "env": {
        "S3_ENDPOINT": "http://minio.echothink.svc:9000",
        "S3_FORCE_PATH_STYLE": "true",
        "S3_BUCKET": "hiclaw-storage",
        "AWS_REGION": "us-east-1",
        "AWS_ACCESS_KEY_ID": "${MINIO_ACCESS_KEY}",
        "AWS_SECRET_ACCESS_KEY": "${MINIO_SECRET_KEY}"
      }
    },
    "hatchet-mcp": {
      "type": "sse",
      "url": "http://hatchet.echothink.svc/mcp",
      "args": [],
      "env": {
        "HATCHET_API_URL": "http://hatchet.echothink.svc",
        "HATCHET_API_TOKEN": "${HATCHET_API_TOKEN}"
      }
    },
    "matrix-mcp": {
      "type": "sse",
      "url": "http://tuwunel.clawcluster.svc:6167/mcp",
      "args": [],
      "env": {
        "MATRIX_HOMESERVER_URL": "http://tuwunel.clawcluster.svc:6167",
        "MATRIX_ACCESS_TOKEN": "${MATRIX_ACCESS_TOKEN_MANAGER}"
      }
    },
    "dify-mcp": {
      "type": "sse",
      "url": "http://dify.echothink.svc/mcp",
      "args": [],
      "env": {
        "DIFY_BASE_URL": "http://dify.echothink.svc",
        "DIFY_API_KEY": "${DIFY_API_KEY}"
      }
    },
    "n8n-mcp": {
      "type": "sse",
      "url": "http://n8n.echothink.svc/mcp",
      "args": [],
      "env": {
        "N8N_BASE_URL": "http://n8n.echothink.svc",
        "N8N_API_KEY": "${N8N_API_KEY}"
      }
    }
  },
  "memory": {
    "type": "file",
    "path": "/workspace/memory",
    "maxSize": "10mb"
  },
  "tools": [
    "task.receive",
    "task.assign",
    "task.update",
    "task.complete",
    "task.cancel",
    "task.escalate",
    "worker.spawn",
    "worker.pause",
    "worker.resume",
    "outline.search",
    "outline.read",
    "gitlab.project.read",
    "gitlab.issue.read",
    "gitlab.merge_request.read",
    "gitlab.pipeline.read",
    "supabase.query",
    "graphiti.read",
    "graphiti.write",
    "minio.read",
    "minio.write",
    "hatchet.run",
    "matrix.read",
    "matrix.send",
    "dify.draft",
    "dify.publish",
    "n8n.draft",
    "n8n.publish",
    "coding.cli.delegate"
  ],
  "workspaceMount": "/workspace/agents/manager",
  "storagePrefix": "hiclaw-storage/agents/manager/",
  "higressConsumerToken": "${HIGRESS_CONSUMER_TOKEN_MANAGER}",
  "matrixUserId": "@manager:${TUWUNEL_SERVER_NAME}",
  "approvalClass": "manager",
  "maxConcurrentTasks": 10,
  "heartbeatIntervalSec": 30,
  "idleTimeoutSec": 3600,
  "logLevel": "info",
  "langfuseEnabled": true
}
