{
  "name": "coding-worker",
  "version": "1.0.0",
  "role": "coding",
  "description": "Coordinates repository-aware code changes and delegates heavy editing through coding CLI.",
  "model": "claude-sonnet-4-6",
  "systemPromptExtensions": [
    "Understand the repository structure and change impact before proposing implementation.",
    "Favor minimal diffs that preserve local conventions and reviewability.",
    "Delegate substantial edits through coding CLI with explicit file, scope, and validation notes.",
    "Always include tests, checks, or explicit test notes with each implementation plan.",
    "Escalate when repository truth, product intent, or validation feasibility is unclear."
  ],
  "mcpServers": {
    "gitlab-mcp": {
      "type": "sse",
      "url": "http://higress.clawcluster.svc/mcp/gitlab",
      "args": [],
      "env": {
        "GITLAB_BASE_URL": "http://gitlab.echothink.svc",
        "GITLAB_API_TOKEN": "${GITLAB_API_TOKEN}",
        "HIGRESS_CONSUMER_TOKEN": "${HIGRESS_CONSUMER_TOKEN_CODING_WORKER}"
      }
    },
    "outline-mcp": {
      "type": "sse",
      "url": "http://outline.echothink.svc/mcp",
      "args": [],
      "env": {
        "OUTLINE_API_URL": "http://outline.echothink.svc/api",
        "OUTLINE_API_TOKEN": "${OUTLINE_API_TOKEN}"
      }
    },
    "graphiti-mcp": {
      "type": "sse",
      "url": "http://graphiti.echothink.svc:8000/mcp",
      "args": [],
      "env": {
        "GRAPHITI_BASE_URL": "http://graphiti.echothink.svc:8000",
        "GRAPHITI_API_TOKEN": "${GRAPHITI_API_TOKEN}"
      }
    },
    "minio-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-s3"
      ],
      "env": {
        "S3_ENDPOINT": "http://minio.echothink.svc:9000",
        "S3_FORCE_PATH_STYLE": "true",
        "S3_BUCKET": "hiclaw-storage",
        "AWS_REGION": "us-east-1",
        "AWS_ACCESS_KEY_ID": "${MINIO_ACCESS_KEY}",
        "AWS_SECRET_ACCESS_KEY": "${MINIO_SECRET_KEY}"
      }
    },
    "matrix-mcp": {
      "type": "sse",
      "url": "http://tuwunel.clawcluster.svc:6167/mcp",
      "args": [],
      "env": {
        "MATRIX_HOMESERVER_URL": "http://tuwunel.clawcluster.svc:6167",
        "MATRIX_ACCESS_TOKEN": "${MATRIX_ACCESS_TOKEN_CODING_WORKER}"
      }
    }
  },
  "memory": {
    "type": "file",
    "path": "/workspace/memory",
    "maxSize": "10mb"
  },
  "tools": [
    "task.receive",
    "task.update",
    "task.complete",
    "task.escalate",
    "gitlab.project.read",
    "gitlab.issue.read",
    "gitlab.merge_request.read",
    "outline.search",
    "outline.read",
    "graphiti.read",
    "graphiti.write",
    "minio.read",
    "minio.write",
    "matrix.read",
    "matrix.send",
    "coding.plan",
    "coding.cli.delegate",
    "test.note.write"
  ],
  "workspaceMount": "/workspace/agents/coding-worker",
  "storagePrefix": "hiclaw-storage/agents/coding-worker/",
  "higressConsumerToken": "${HIGRESS_CONSUMER_TOKEN_CODING_WORKER}",
  "matrixUserId": "@coding-worker:${TUWUNEL_SERVER_NAME}",
  "approvalClass": "coding",
  "maxConcurrentTasks": 2,
  "heartbeatIntervalSec": 30,
  "idleTimeoutSec": 300,
  "logLevel": "info",
  "langfuseEnabled": true
}
