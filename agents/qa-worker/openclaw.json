{
  "name": "qa-worker",
  "version": "1.0.0",
  "role": "qa",
  "description": "Validates outputs with evidence-based checks, clear findings, and explicit approval gates.",
  "model": "claude-sonnet-4-6",
  "systemPromptExtensions": [
    "Do not approve behavior that has not been verified with meaningful evidence.",
    "Distinguish passed, failed, partially verified, and blocked states clearly.",
    "Focus first on acceptance criteria, regressions, and the strength of available evidence.",
    "Report findings with reproducible scope, observations, gaps, and recommended next steps.",
    "Escalate when verification is blocked by environment limits or unclear requirements."
  ],
  "mcpServers": {
    "gitlab-mcp": {
      "type": "sse",
      "url": "http://higress.clawcluster.svc/mcp/gitlab",
      "args": [],
      "env": {
        "GITLAB_BASE_URL": "http://gitlab.echothink.svc",
        "GITLAB_API_TOKEN": "${GITLAB_API_TOKEN}",
        "HIGRESS_CONSUMER_TOKEN": "${HIGRESS_CONSUMER_TOKEN_QA_WORKER}"
      }
    },
    "minio-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "mcp-server-s3"
      ],
      "env": {
        "S3_ENDPOINT": "http://minio.echothink.svc:9000",
        "S3_FORCE_PATH_STYLE": "true",
        "S3_BUCKET": "hiclaw-storage",
        "AWS_REGION": "us-east-1",
        "AWS_ACCESS_KEY_ID": "${MINIO_ACCESS_KEY}",
        "AWS_SECRET_ACCESS_KEY": "${MINIO_SECRET_KEY}"
      }
    },
    "supabase-mcp": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase"
      ],
      "env": {
        "SUPABASE_URL": "http://supabase-kong.echothink.svc:8000",
        "SUPABASE_SERVICE_ROLE_KEY": "${SUPABASE_SERVICE_ROLE_KEY}",
        "POSTGRES_URL": "${POSTGRES_URL}"
      }
    },
    "matrix-mcp": {
      "type": "sse",
      "url": "http://tuwunel.clawcluster.svc:6167/mcp",
      "args": [],
      "env": {
        "MATRIX_HOMESERVER_URL": "http://tuwunel.clawcluster.svc:6167",
        "MATRIX_ACCESS_TOKEN": "${MATRIX_ACCESS_TOKEN_QA_WORKER}"
      }
    }
  },
  "memory": {
    "type": "file",
    "path": "/workspace/memory",
    "maxSize": "10mb"
  },
  "tools": [
    "task.receive",
    "task.update",
    "task.complete",
    "task.escalate",
    "gitlab.project.read",
    "gitlab.merge_request.read",
    "gitlab.pipeline.read",
    "minio.read",
    "minio.write",
    "supabase.query",
    "matrix.read",
    "matrix.send",
    "qa.plan",
    "qa.validate",
    "qa.report"
  ],
  "workspaceMount": "/workspace/agents/qa-worker",
  "storagePrefix": "hiclaw-storage/agents/qa-worker/",
  "higressConsumerToken": "${HIGRESS_CONSUMER_TOKEN_QA_WORKER}",
  "matrixUserId": "@qa-worker:${TUWUNEL_SERVER_NAME}",
  "approvalClass": "qa",
  "maxConcurrentTasks": 3,
  "heartbeatIntervalSec": 30,
  "idleTimeoutSec": 300,
  "logLevel": "info",
  "langfuseEnabled": true
}
