{
  "gateway": {
    "mode": "local",
    "port": 18800,
    "auth": {
      "token": "${HIGRESS_CONSUMER_TOKEN_QA_WORKER}"
    },
    "remote": {
      "token": "${HIGRESS_CONSUMER_TOKEN_QA_WORKER}"
    }
  },
  "channels": {
    "matrix": {
      "enabled": true,
      "homeserver": "${HICLAW_MATRIX_SERVER}",
      "accessToken": "${MATRIX_ACCESS_TOKEN_QA_WORKER}",
      "dm": {
        "policy": "allowlist",
        "allowFrom": [
          "@${HICLAW_ADMIN_USER}:${TUWUNEL_SERVER_NAME}"
        ]
      },
      "groupPolicy": "allowlist",
      "groupAllowFrom": [
        "@manager:${TUWUNEL_SERVER_NAME}",
        "@${HICLAW_ADMIN_USER}:${TUWUNEL_SERVER_NAME}"
      ],
      "groups": {
        "*": {
          "allow": true,
          "requireMention": true
        }
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "hiclaw-gateway": {
        "baseUrl": "${LITELLM_URL}/v1",
        "apiKey": "${LITELLM_API_KEY}",
        "api": "openai-completions",
        "models": [
          {
            "id": "cost-effective",
            "name": "cost-effective",
            "reasoning": true,
            "contextWindow": 960000,
            "maxTokens": 64000,
            "input": [
              "text",
              "image"
            ]
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "timeoutSeconds": 1800,
      "workspace": "/root",
      "model": {
        "primary": "hiclaw-gateway/cost-effective"
      },
      "maxConcurrent": 3,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },
  "session": {
    "resetByType": {
      "dm": {
        "mode": "daily",
        "atHour": 4
      },
      "group": {
        "mode": "idle",
        "idleMinutes": 2880
      }
    }
  },
  "plugins": {
    "load": {
      "paths": [
        "/opt/openclaw/extensions/matrix"
      ]
    },
    "entries": {
      "matrix": {
        "enabled": true
      }
    }
  }
}
